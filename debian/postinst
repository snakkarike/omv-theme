#!/bin/sh

set -e

case "$1" in
    configure)
        # Rebuild the OMV workbench UI cache so new YAML files appear.
        dpkg-trigger update-workbench

        # Clean up deprecated wallpaper config keys from the XML database to prevent AssertException
        if command -v xmlstarlet >/dev/null 2>&1; then
            xmlstarlet ed -L -d "//services/themekit/loginwallpaper" /etc/openmediavault/config.xml || true
            xmlstarlet ed -L -d "//services/themekit/standbywallpaper" /etc/openmediavault/config.xml || true
            xmlstarlet ed -L -d "//services/themekit/shutdownwallpaper" /etc/openmediavault/config.xml || true
        fi

        # Register (or update) the config database schema for this plugin.
        omv-confdbadm create "conf.service.themekit"

        # Ensure all new schema properties exist in the XML database so RPC works correctly
        # We use Python and omv-confdbadm to guarantee compatibility without xmlstarlet
        CURRENT_CONF=$(omv-confdbadm read "conf.service.themekit" 2>/dev/null || echo "{}")
        NEW_CONF=$(python3 -c "
import json, sys
try:
    data = json.loads(sys.argv[1])
    if isinstance(data, list) and len(data) > 0:
        data = data[0]
    elif isinstance(data, list):
        data = {}
        
    defaults = {
        'baseFontSize': 16,
        'fontCategory': 'all',
        'customCss': '',
        'customFont_all': '',
        'customFont_sans_serif': '',
        'customFont_serif': '',
        'customFont_display': '',
        'customFont_handwriting': '',
        'customFont_monospace': ''
    }
    
    dirty = False
    for k, v in defaults.items():
        if k == 'baseFontSize' and (k not in data or not str(data.get(k, '')).isdigit()):
            data[k] = v
            dirty = True
        elif k not in data:
            data[k] = v
            dirty = True
            
    if dirty:
        print(json.dumps(data))
    else:
        print('NOT_DIRTY')
except Exception as e:
    print('NOT_DIRTY')
" "$CURRENT_CONF")

        if [ "$NEW_CONF" != "NOT_DIRTY" ] && [ -n "$NEW_CONF" ]; then
            omv-confdbadm update "conf.service.themekit" "$NEW_CONF" || true
        fi

        # Render the CSS based on current settings.
        omv-salt deploy run themekit || true

        # Refresh the services that serve the web UI.
        systemctl restart phpsessionclean.timer 2>/dev/null || true
        systemctl reload-or-restart nginx 2>/dev/null || true
        for f in /etc/init.d/php*-fpm; do
            [ -x "$f" ] && "$f" reload 2>/dev/null || true
        done
        systemctl restart openmediavault-engined 2>/dev/null || true
        ;;
    triggered)
        # Re-apply the salt state when index.html is replaced by a webgui update
        omv-salt deploy run themekit || true
        ;;
esac

#DEBHELPER#

exit 0
