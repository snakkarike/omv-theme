/* Generated by openmediavault-themekit. Do not edit directly, edit via
   System > Theme Kit in the web UI instead, your changes will be
   overwritten on the next deploy.

   These custom properties are the ones actually confirmed present in
   OMV 8.5.1's compiled styles.<hash>.css (grep'd directly off a live
   box), not guessed. This file is injected via a <link> appended after
   the hash-named stylesheet in index.html, so redefining the same
   :root variables here wins on source order without needing
   !important anywhere. */

:root {
{%- if mode == "dark" %}
  --mat-background-color-body: #14181c;
  --mat-background-color-background: #1a1f24;
  --mat-background-color-card: #1d2227;
  --mat-background-color-hover: rgb(255 255 255 / 6%);
  --mat-background-color-selected-button: #2a3138;
  --mat-color-text: rgba(255, 255, 255, .92);
  --mat-color-secondary-text: rgba(255, 255, 255, .64);
  --mat-color-disabled-text: rgba(255, 255, 255, .38);
  --mat-color-hint-text: rgba(255, 255, 255, .38);
  --omv-background-color-muted: rgb(255 255 255 / 10%);
  --omv-background-color-muted-text: rgb(255 255 255 / 6%);
{%- else %}
  --mat-background-color-body: #eef0f2;
  --mat-background-color-background: #eef0f2;
  --mat-background-color-card: #ffffff;
  --mat-background-color-hover: rgb(0 0 0 / 4%);
  --mat-background-color-selected-button: #9ba6b1;
  --mat-color-text: rgba(0, 0, 0, .87);
  --mat-color-secondary-text: rgba(0, 0, 0, .54);
  --mat-color-disabled-text: rgba(0, 0, 0, .38);
  --mat-color-hint-text: rgba(0, 0, 0, .38);
  --omv-background-color-muted: rgb(0 0 0 / 10%);
  --omv-background-color-muted-text: rgb(0 0 0 / 6%);
{%- endif %}

{%- if accent == "red" %}
  --mat-primary-color-text: #d64545;
{%- elif accent == "citrus" %}
  --mat-primary-color-text: #e8a13b;
{%- elif accent == "lime" %}
  --mat-primary-color-text: #8bc34a;
{%- elif accent == "sky" %}
  --mat-primary-color-text: #3b9be8;
{%- elif accent == "plum" %}
  --mat-primary-color-text: #8e44ad;
{%- elif accent == "rose" %}
  --mat-primary-color-text: #e84393;
{%- else %}
  --mat-primary-color-text: #295185;
{%- endif %}
}

body {
  background-color: var(--mat-background-color-body);
  color: var(--mat-color-text);
}

/* NOTE: the variable set above only covers what's referenced at the
   :root level in the compiled stylesheet, mostly typography plus a
   handful of color tokens. Angular Material 17+ (MDC-based) components
   often pull from their own --mdc-* / --mat-sys-* tokens per
   component, which weren't in the confirmed list. If specific pieces
   of chrome (toolbar, sidenav, cards) don't pick up the color after
   this loads, open devtools, inspect that element, find which
   --mdc-*/--mat-* variable it's actually reading, and add an override
   for it here. */
